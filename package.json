{
  "name": "dart-packages",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --stream build",
    "dev": "pnpm -r --stream dev",
    "lint": "eslint",
    "prepare": "husky",
    "release": "run-s release:check build release:publish",
    "release:check": "run-s build lint typecheck test",
    "release:publish": "changeset publish",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@ntnyq/eslint-config": "^7.0.0-beta.8",
    "@ntnyq/prettier-config": "^3.1.0",
    "@types/node": "^26.0.1",
    "@typescript/native-preview": "^7.0.0-dev.20260629.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "nano-staged": {
    "*.{js,ts,mjs,cjs,md,yml,yaml,json}": "eslint --fix"
  }
}
